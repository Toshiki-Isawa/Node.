// Copy to Secrets.xcconfig and fill in your values.
SUPABASE_URL = https:/$()/YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = your-anon-key

// Google Cloud Console の iOS OAuth クライアント ID
GOOGLE_IOS_CLIENT_ID = your-google-ios-client-id.apps.googleusercontent.com
// REVERSED_CLIENT_ID（GoogleService-Info.plist と同じ値）
GOOGLE_IOS_URL_SCHEME = com.googleusercontent.apps.your-client-id-prefix
