# Copy to supabase/functions/.env for local Edge Functions (supabase start で自動読込)
# 本番は supabase secrets set --env-file supabase/functions/.env

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=node-observations
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# 公開 CDN / カスタムドメイン（任意）。例: https://images.example.com
R2_PUBLIC_BASE_URL=
